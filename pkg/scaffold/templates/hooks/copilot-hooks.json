{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/observe.js sessionStart",
        "powershell": "node .github/hooks/scripts/observe.js sessionStart",
        "timeoutSec": 5
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/observe.js sessionEnd",
        "powershell": "node .github/hooks/scripts/observe.js sessionEnd",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/observe.js userPromptSubmitted",
        "powershell": "node .github/hooks/scripts/observe.js userPromptSubmitted",
        "timeoutSec": 5
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/observe.js preToolUse",
        "powershell": "node .github/hooks/scripts/observe.js preToolUse",
        "timeoutSec": 5
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/observe.js postToolUse",
        "powershell": "node .github/hooks/scripts/observe.js postToolUse",
        "timeoutSec": 5
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/observe.js errorOccurred",
        "powershell": "node .github/hooks/scripts/observe.js errorOccurred",
        "timeoutSec": 5
      }
    ]
  }
}
