{
  "name": "atv-launchpad",
  "displayName": "ATV Launchpad",
  "description": "Live dashboard for ATV StarterKit — shows repo memory, context health, install drift, and recommended moves.",
  "version": "0.1.0",
  "publisher": "all-the-vibes",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "workspaceContains:.atv/"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "atvLaunchpad.open",
        "title": "ATV: Open Launchpad"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
